---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  { href: '/category/planter/',      emoji: '🪴', label: 'プランター',       desc: '底穴・サイズ・素材の選び方。根腐れゼロのスリット鉢から始める。' },
  { href: '/category/soil/',         emoji: '🌱', label: '土・培養土',       desc: 'pH・通気・有機質のバランス。失敗の3割は土で決まる。' },
  { href: '/category/fertilizer/',   emoji: '💊', label: '肥料',             desc: '元肥・追肥・液肥の使い分け。「肥料切れ」を数値で判断する。' },
  { href: '/category/tools/',        emoji: '🔧', label: '道具',             desc: 'ジョウロ・移植ゴテ・pH計。測れるものは測る。' },
  { href: '/category/pest-control/', emoji: '🛡️', label: '害虫・病気対策',  desc: '防虫ネットが最初の防衛ライン。農薬は最後の手段。' },
  { href: '/category/herb/',         emoji: '🌿', label: 'ハーブ',           desc: 'バジル・シソ・ミント。ベランダで育てやすい品種から。' },
  { href: '/category/tomato/',       emoji: '🍅', label: 'ミニトマト',       desc: '支柱と誘引が収穫量を決める。接ぎ木苗で病気リスクを下げる。' },
  { href: '/category/summer-vege/',  emoji: '🥒', label: '夏野菜',           desc: 'なす・きゅうり。肥料と水を切らさないことが全て。' },
];
---
<BaseLayout
  title="プランターノート — 失敗ノートから選ぶ家庭菜園アイテム"
  description="家庭菜園歴12年の増田博之が失敗から選んだプランター・土・肥料のおすすめ品を紹介します。品質管理の思考で「なぜ失敗するか」を記録し続けた6冊のノートから厳選。"
>
  <section class="hero-section">
    <p class="hero-lead">
      プランター菜園は<br />土と水のコントロールがすべて
    </p>
    <p style="font-size:1rem; line-height:1.9; margin:0 0 1.2rem; color:var(--color-text-muted);">
      品質管理の仕事を30年続けた増田博之が、12年間の家庭菜園で書いた失敗ノート6冊から<br />
      「本当に使えるアイテム」だけを選んで紹介するサイトです。
    </p>
    <div class="hero-badges">
      <span class="hero-badge">🌱 菜園歴12年</span>
      <span class="hero-badge">📔 失敗ノート6冊</span>
      <span class="hero-badge">🔬 品質管理思考</span>
      <span class="hero-badge">🪴 プランター専門</span>
    </div>
  </section>

  <section style="background:linear-gradient(135deg,#f0f7ee,#e8f5e2); border-radius:14px; padding:1.4rem 1.2rem; margin:0.5rem 0 2rem; border:1px solid var(--color-border);">
    <h2 style="margin:0 0 0.5rem; border-left:4px solid var(--color-accent); padding-left:0.6rem; font-size:1.1rem; color:var(--color-accent);">
      📚 Kindle本をお読みの方へ
    </h2>
    <p style="margin:0 0 0.8rem; font-size:0.95rem; line-height:1.8;">
      本の中で紹介した商品・おすすめアイテムを、カテゴリ別にまとめたページをご用意しています。
    </p>
    <a href="/kindle-guide/" style="display:inline-block; background:var(--color-accent); color:#fff; padding:0.65rem 1.4rem; border-radius:7px; text-decoration:none; font-weight:700; font-size:0.95rem;">
      → 本をお読みの方はこちら
    </a>
  </section>

  <section>
    <h2>カテゴリから探す</h2>
    <div class="category-grid">
      {categories.map((c) => (
        <a href={c.href} class="card" style="text-decoration:none; color:inherit;">
          <div style="font-size:1.8rem; margin-bottom:0.3rem;">{c.emoji}</div>
          <h3 style="margin:0 0 0.35rem; font-size:1rem;">{c.label}</h3>
          <p style="margin:0; font-size:0.86rem; color:var(--color-text-muted); line-height:1.65;">{c.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <section style="margin-top:2.8rem; padding:1.4rem 1.2rem; border:1px solid var(--color-border); border-radius:12px; background:#fafcfa;">
    <h2 style="margin:0 0 0.8rem;">増田博之のプランター菜園の考え方</h2>
    <p style="margin:0 0 0.8rem; line-height:1.9;">
      品質管理の仕事を30年続けると、「なぜ失敗するか」を記録することが習慣になります。
      家庭菜園でも同じで、失敗のたびにノートを書き続けて6冊になりました。
    </p>
    <p style="margin:0 0 0.8rem; line-height:1.9;">
      気づいたのは、ほとんどの失敗が「根腐れ」「肥料切れ」「pH異常」の3つに集中しているということです。
      この3つを数値で管理できるようになると、収穫は安定します。
    </p>
    <p style="margin:0; line-height:1.9; color:var(--color-text-muted); font-size:0.92rem;">
      このサイトでは、私が実際に使ってみて「失敗が減った」と感じたアイテムだけを紹介しています。
      良い点だけでなく、使ってみて気になった点も正直に書くようにしています。
    </p>
  </section>

  <section style="margin-top:2rem; font-size:0.8rem; color:var(--color-text-muted); line-height:1.7; padding:0.8rem; border:1px dashed var(--color-border); border-radius:8px;">
    ※ 当サイトの「増田博之」は架空のキャラクターです。紹介商品はAmazon.co.jpアソシエイトプログラムを通じた広告リンクを含みます。
    詳しくは<a href="/privacy-policy/">プライバシーポリシー</a>をご覧ください。
  </section>
</BaseLayout>
