---
const nav = [
  { href: '/', label: 'ホーム' },
  { href: '/category/planter/', label: 'プランター' },
  { href: '/category/soil/', label: '土・培養土' },
  { href: '/category/fertilizer/', label: '肥料' },
  { href: '/category/tools/', label: '道具' },
  { href: '/kindle-guide/', label: '本をお読みの方へ' },
  { href: '/about/', label: 'About' },
];
const path = Astro.url.pathname;
---
<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="site-logo">🌱 プランターノート</a>
    <nav class="site-nav" aria-label="サイトナビ">
      {nav.map((n) => (
        <a href={n.href} aria-current={path === n.href ? 'page' : undefined}>
          {n.label}
        </a>
      ))}
    </nav>
  </div>
</header>
